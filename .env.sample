# =====================================================================
# OpenAlgo Execution Skills - Environment Variables
# Copy to .env and fill in your values.
# =====================================================================

# --- OpenAlgo Platform ---
# Get the API key from your local OpenAlgo dashboard.
OPENALGO_API_KEY=your_openalgo_api_key_here

# REST host - canonical name in OpenAlgo's own .env is HOST_SERVER.
# Both names are read by templates; HOST_SERVER wins if both set.
HOST_SERVER=http://127.0.0.1:5000
OPENALGO_HOST=http://127.0.0.1:5000

# WebSocket URL - canonical name is WEBSOCKET_URL.
WEBSOCKET_URL=ws://127.0.0.1:8765
WEBSOCKET_HOST=127.0.0.1
WEBSOCKET_PORT=8765

# --- Strategy Defaults ---
# When run via OpenAlgo /python host, this is overridden by
# OPENALGO_STRATEGY_EXCHANGE injected by the platform.
EXCHANGE=NSE

# Default execution mode when --mode flag is not passed.
# Acceptable values: backtest | live
MODE=live

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Optional: Telegram Alerts ---
# Set the username registered in your OpenAlgo Telegram bot.
TELEGRAM_USERNAME=

# --- Optional: Custom data providers (only if you extend) ---
# ALPACA_API_KEY=
# TWELVEDATA_API_KEY=
